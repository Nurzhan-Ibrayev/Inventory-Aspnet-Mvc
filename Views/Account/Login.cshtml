@model ItransitionProjectMVC.ViewModels.Account.LoginViewModel

@{
    ViewData["Title"] = "Вход";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5 shadow p-4 border rounded bg-white">
            <h2 class="text-center mb-4">Вход в систему</h2>

            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label font-weight-bold">Электронная почта</label>
                    <input asp-for="Email" class="form-control" placeholder="example@mail.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label font-weight-bold">Пароль</label>
                    <input asp-for="Password" class="form-control" type="password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label">Запомнить меня</label>
                </div>

                <button type="submit" class="btn btn-success w-100 py-2">Войти</button>
            </form>

            <div class="mt-3 text-center">
                <p>Нет аккаунта? <a asp-action="Register" class="text-decoration-none">Создать</a></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}