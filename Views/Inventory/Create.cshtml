@model ItransitionProjectMVC.ViewModels.Inventory.CreateInventoryViewModel

@{
    ViewData["Title"] = "Create Inventory";
}

<div class="row justify-content-center">

    <div class="col-xl-10">

        <div class="card card-modern">

            <div class="card-body p-4 p-lg-5">

                <div class="mb-5">
                    <h1 class="page-title">
                        Create Inventory
                    </h1>

                    <p class="text-muted">
                        Configure inventory information and custom item fields
                    </p>
                </div>

                <form asp-action="Create" method="post">

                    <!-- BASIC INFO -->

                    <div class="section-title">
                        Basic Information
                    </div>

                    <div class="row g-4 mb-5">

                        <div class="col-12">

                            <label asp-for="Title" class="form-label fw-semibold"></label>

                            <input asp-for="Title"
                                   class="form-control form-control-lg"
                                   placeholder="Gaming Setup Collection" />

                            <span asp-validation-for="Title"
                                  class="text-danger small"></span>

                        </div>

                        <div class="col-12">

                            <label asp-for="Description"
                                   class="form-label fw-semibold"></label>

                            <textarea asp-for="Description"
                                      rows="6"
                                      class="form-control"
                                      placeholder="Markdown supported..."></textarea>

                        </div>

                        <div class="col-md-6">

                            <label asp-for="CategoryId"
                                   class="form-label fw-semibold"></label>

                            <select asp-for="CategoryId"
                                    asp-items="Model.Categories"
                                    class="form-select">

                                <option value="">
                                    Select category
                                </option>

                            </select>

                        </div>

                        <div class="col-md-6">

                            <label asp-for="Tags"
                                   class="form-label fw-semibold"></label>

                            <input asp-for="Tags"
                                   class="form-control"
                                   placeholder="tech, gaming, pc" />

                        </div>

                        <div class="col-12">

                            <label asp-for="ImageUrl"
                                   class="form-label fw-semibold">
                                Image URL
                            </label>

                            <input asp-for="ImageUrl"
                                   class="form-control"
                                   placeholder="https://..." />

                        </div>

                        <div class="col-12">

                            <div class="form-check modern-checkbox">

                                <input asp-for="IsPublic"
                                       class="form-check-input" />

                                <label asp-for="IsPublic"
                                       class="form-check-label fw-semibold">
                                </label>

                            </div>

                        </div>

                    </div>

                    <!-- STRING FIELDS -->

                    <div class="section-title">
                        String Fields
                    </div>

                    <div class="row g-4 mb-5">

                        @for (int i = 1; i <= 3; i++)
                        {
                            <div class="col-lg-4">

                                <div class="custom-field-card">

                                    <div class="field-badge">
                                        String #@i
                                    </div>

                                    <div class="mb-3">

                                        <label class="form-label fw-semibold">
                                            Field Name
                                        </label>

                                        <input name="CustomString@(i)Name"
                                               value="@ViewData.Model?.GetType().GetProperty($"CustomString{i}Name")?.GetValue(Model)"
                                               class="form-control"
                                               placeholder="CPU / Brand / Color" />

                                    </div>

                                    <div>

                                        <label class="form-label fw-semibold">
                                            Visibility
                                        </label>

                                        <select name="CustomString@(i)State"
                                                class="form-select">

                                            <option value="Hidden">Hidden</option>
                                            <option value="Optional">Optional</option>
                                            <option value="Required">Required</option>

                                        </select>

                                    </div>

                                </div>

                            </div>
                        }

                    </div>

                    <!-- MULTILINE -->

                    <div class="section-title">
                        Multiline Text Fields
                    </div>

                    <div class="row g-4 mb-5">

                        @for (int i = 1; i <= 3; i++)
                        {
                            <div class="col-lg-4">

                                <div class="custom-field-card">

                                    <div class="field-badge">
                                        Text #@i
                                    </div>

                                    <div class="mb-3">

                                        <label class="form-label fw-semibold">
                                            Field Name
                                        </label>

                                        <input name="CustomMultiline@(i)Name"
                                               class="form-control"
                                               placeholder="Description / Notes" />

                                    </div>

                                    <select name="CustomMultiline@(i)State"
                                            class="form-select">

                                        <option value="Hidden">Hidden</option>
                                        <option value="Optional">Optional</option>
                                        <option value="Required">Required</option>

                                    </select>

                                </div>

                            </div>
                        }

                    </div>

                    <!-- NUMBER -->

                    <div class="section-title">
                        Numeric Fields
                    </div>

                    <div class="row g-4 mb-5">

                        @for (int i = 1; i <= 3; i++)
                        {
                            <div class="col-lg-4">

                                <div class="custom-field-card">

                                    <div class="field-badge">
                                        Number #@i
                                    </div>

                                    <div class="mb-3">

                                        <input name="CustomInt@(i)Name"
                                               class="form-control"
                                               placeholder="Price / Year / Weight" />

                                    </div>

                                    <select name="CustomInt@(i)State"
                                            class="form-select">

                                        <option value="Hidden">Hidden</option>
                                        <option value="Optional">Optional</option>
                                        <option value="Required">Required</option>

                                    </select>

                                </div>

                            </div>
                        }

                    </div>

                    <!-- BOOL -->

                    <div class="section-title">
                        Boolean Fields
                    </div>

                    <div class="row g-4 mb-5">

                        @for (int i = 1; i <= 3; i++)
                        {
                            <div class="col-lg-4">

                                <div class="custom-field-card">

                                    <div class="field-badge">
                                        Checkbox #@i
                                    </div>

                                    <div class="mb-3">

                                        <input name="CustomBool@(i)Name"
                                               class="form-control"
                                               placeholder="Available / Used" />

                                    </div>

                                    <select name="CustomBool@(i)State"
                                            class="form-select">

                                        <option value="Hidden">Hidden</option>
                                        <option value="Optional">Optional</option>
                                        <option value="Required">Required</option>

                                    </select>

                                </div>

                            </div>
                        }

                    </div>

                    <!-- LINKS -->

                    <div class="section-title">
                        Link Fields
                    </div>

                    <div class="row g-4 mb-5">

                        @for (int i = 1; i <= 3; i++)
                        {
                            <div class="col-lg-4">

                                <div class="custom-field-card">

                                    <div class="field-badge">
                                        Link #@i
                                    </div>

                                    <div class="mb-3">

                                        <input name="CustomLink@(i)Name"
                                               class="form-control"
                                               placeholder="Manual / Website" />

                                    </div>

                                    <select name="CustomLink@(i)State"
                                            class="form-select">

                                        <option value="Hidden">Hidden</option>
                                        <option value="Optional">Optional</option>
                                        <option value="Required">Required</option>

                                    </select>

                                </div>

                            </div>
                        }

                    </div>

                    <div class="d-flex gap-3 mt-5">

                        <button type="submit"
                                class="btn btn-dark btn-modern flex-grow-1">

                            Create Inventory

                        </button>

                        <a asp-controller="Home"
                           asp-action="Index"
                           class="btn btn-outline-secondary btn-modern">

                            Cancel

                        </a>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}