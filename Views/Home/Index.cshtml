@model IEnumerable<ItransitionProjectMVC.ViewModels.Inventory.InventoryViewModel>

@{
    ViewData["Title"] = "Список инвентарей";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-6">Доступные инвентари</h1>
        @if (User.Identity.IsAuthenticated)
        {
            <a asp-controller="Inventory" asp-action="Create" class="btn btn-success shadow-sm">
                <i class="bi bi-plus-circle"></i> Создать новый
            </a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-light text-center border py-5">
            <p class="text-muted mb-0">Пока ничего не создано. Будьте первым!</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm hover-card">
                        <div class="card-body">
                            <h5 class="card-title text-primary">@item.Title</h5>
                            <p class="card-text text-secondary text-truncate-3">
                                @item.Description
                            </p>
                        </div>
                        
                        <div class="card-footer bg-transparent border-top-0 pb-3">
                            <div class="d-flex gap-2">

                                <a asp-controller="Item"
                                   asp-action="Index"
                                   asp-route-id="@item.Id"
                                   class="btn btn-outline-primary btn-sm w-100">
                                    Open
                                </a>

                                <a asp-controller="Inventory"
                                   asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-outline-warning btn-sm">
                                    Edit
                                </a>

                                <form asp-controller="Inventory"
                                      asp-action="Delete"
                                      asp-route-id="@item.Id"
                                      method="post">

                                    @Html.AntiForgeryToken()

                                    <button type="submit"
                                            class="btn btn-outline-danger btn-sm"
                                            onclick="return confirm('Delete inventory?')">
                                        Delete
                                    </button>
                                </form>

                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>